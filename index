<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>InteliHouse | Instalacje pod inteligentny dom</title>
<meta name="description" content="InteliHouse, kompleksowe przygotowanie instalacji elektrycznej pod inteligentny dom. Certyfikowane wykonanie, cała Polska.">
<meta property="og:title" content="InteliHouse | Zamieszkaj w przyszłości">
<meta property="og:description" content="Instalacje pod inteligentny dom w całej Polsce. Wyceń swoją instalację online.">
<meta property="og:type" content="website"><link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23070606'/%3E%3Cpath d='M50 18 L80 42 L80 82 L20 82 L20 42 Z' fill='none' stroke='%23ff6a1a' stroke-width='6'/%3E%3Ccircle cx='50' cy='55' r='11' fill='none' stroke='%23ff6a1a' stroke-width='5'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#14120f;
  --bg-2:#1a1714;
  --surface:#201c18;
  --surface-2:#282320;
  --line:#332e29;
  --line-2:#413b34;
  --txt:#f7f4f0;
  --muted:#a49c94;
  --muted-2:#7a726a;
  --orange:#ff7a2e;
  --orange-soft:#ffab63;
  --orange-deep:#d1591c;
  --glow:rgba(255,138,60,.5);
  --maxw:1200px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  background:var(--bg);color:var(--txt);
  font-family:'Inter',system-ui,sans-serif;line-height:1.6;
  -webkit-font-smoothing:antialiased;overflow-x:hidden;
}
h1,h2,h3,.display{font-family:'Space Grotesk',sans-serif;line-height:1.04;letter-spacing:-.02em;font-weight:700}
.mono{font-family:'JetBrains Mono',monospace}
a{color:inherit;text-decoration:none}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 26px}
.orange{color:var(--orange)}
::selection{background:var(--orange);color:#231d18}

.eyebrow{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.28em;
  text-transform:uppercase;color:var(--orange);display:inline-flex;align-items:center;gap:10px}
.eyebrow::before{content:"";width:22px;height:1px;background:var(--orange);display:inline-block}

/* ---------- global energy canvas ---------- */
#energy{position:fixed;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;opacity:.9}
.vignette{position:fixed;inset:0;z-index:1;pointer-events:none;
  background:radial-gradient(120% 90% at 50% -10%, transparent 45%, rgba(20,18,15,.5) 82%, var(--bg) 100%)}
main,header,footer{position:relative;z-index:2}

/* ---------- header ---------- */
header{position:fixed;top:0;left:0;right:0;z-index:60;transition:background .3s,border-color .3s,backdrop-filter .3s;
  border-bottom:1px solid transparent}
header.scrolled{background:rgba(20,18,15,.78);backdrop-filter:blur(16px) saturate(1.3);border-bottom-color:var(--line)}
.nav{display:flex;align-items:center;justify-content:space-between;height:76px}
.brand{display:flex;align-items:center;gap:12px;font-family:'Space Grotesk';font-weight:700;font-size:1.28rem;letter-spacing:-.01em}
.brand .logo{width:38px;height:38px;flex:0 0 38px}
.nav-links{display:flex;gap:34px;align-items:center}
.nav-links a{font-family:'JetBrains Mono',monospace;color:var(--muted);font-size:.82rem;letter-spacing:.02em;
  position:relative;transition:color .25s;padding:4px 0}
.nav-links a::after{content:"";position:absolute;left:0;bottom:-2px;width:0;height:1px;background:var(--orange);transition:width .3s}
.nav-links a:hover{color:var(--txt)}
.nav-links a:hover::after{width:100%}
.nav-cta{border:1px solid var(--line-2);border-radius:100px;padding:10px 22px !important;color:var(--txt) !important;
  transition:border-color .25s,background .25s !important}
.nav-cta::after{display:none}
.nav-cta:hover{border-color:var(--orange);background:rgba(255,106,26,.08)}
.burger{display:none;flex-direction:column;gap:6px;background:none;border:0;cursor:pointer;padding:8px;z-index:70}
.burger span{width:26px;height:2px;background:var(--txt);display:block;transition:.35s}
.burger.open span:nth-child(1){transform:translateY(8px) rotate(45deg)}
.burger.open span:nth-child(2){opacity:0}
.burger.open span:nth-child(3){transform:translateY(-8px) rotate(-45deg)}
@media(max-width:900px){
  .nav-links{position:fixed;inset:0;flex-direction:column;justify-content:center;gap:30px;
    background:rgba(20,18,15,.97);backdrop-filter:blur(20px);
    clip-path:circle(0% at 100% 0);transition:clip-path .5s cubic-bezier(.7,0,.3,1)}
  .nav-links.open{clip-path:circle(150% at 100% 0)}
  .nav-links a{font-size:1.1rem}
  .burger{display:flex}
}

/* ---------- hero ---------- */
.hero{min-height:100svh;display:flex;flex-direction:column;justify-content:center;
  padding:120px 0 60px;position:relative}
.hero .wrap{width:100%}
.hero-eyebrow{margin-bottom:34px;opacity:0;animation:fadeUp .8s .2s forwards}
.hero h1{font-size:clamp(2.9rem,8.5vw,7rem);font-weight:700;letter-spacing:-.03em;max-width:16ch}
.hero h1 .l{display:block;overflow:hidden}
.hero h1 .l span{display:block;transform:translateY(110%);animation:lineUp .9s cubic-bezier(.22,.9,.3,1) forwards}
.hero h1 .l:nth-child(1) span{animation-delay:.35s}
.hero h1 .l:nth-child(2) span{animation-delay:.5s}
.hero h1 .grad{background:linear-gradient(100deg,var(--orange),var(--orange-soft) 60%,#ffd9b8);
  -webkit-background-clip:text;background-clip:text;color:transparent}
.hero p.lead{color:var(--muted);font-size:clamp(1.05rem,2vw,1.3rem);max-width:52ch;margin:34px 0 44px;
  opacity:0;animation:fadeUp .9s .85s forwards}
.hero-cta{display:flex;gap:16px;flex-wrap:wrap;opacity:0;animation:fadeUp .9s 1s forwards}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:11px;padding:16px 32px;border-radius:100px;
  font-family:'JetBrains Mono',monospace;font-size:.85rem;letter-spacing:.04em;font-weight:500;cursor:pointer;
  border:1px solid transparent;transition:transform .2s,background .25s,border-color .25s,box-shadow .3s;position:relative}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--orange);color:#231d18;box-shadow:0 0 0 rgba(255,138,60,0)}
.btn-primary:hover{background:var(--orange-soft);box-shadow:0 8px 40px -6px var(--glow);transform:translateY(-2px)}
.btn-ghost{border-color:var(--line-2);color:var(--txt)}
.btn-ghost:hover{border-color:var(--orange);color:var(--orange);transform:translateY(-2px)}
.btn .arrow{transition:transform .25s}
.btn:hover .arrow{transform:translateX(4px)}
.hero-scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
  font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.2em;color:var(--muted-2);
  display:flex;flex-direction:column;align-items:center;gap:10px;opacity:0;animation:fadeUp 1s 1.4s forwards}
.hero-scroll .bar{width:1px;height:44px;background:linear-gradient(var(--orange),transparent);position:relative;overflow:hidden}
.hero-scroll .bar::after{content:"";position:absolute;top:-44px;left:0;width:1px;height:44px;
  background:var(--txt);animation:scrollDot 2s ease-in-out infinite}

/* ---------- ticker ---------- */
.ticker{border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  padding:20px 0;overflow:hidden;background:rgba(26,23,20,.5);backdrop-filter:blur(4px)}
.ticker-track{display:flex;gap:56px;white-space:nowrap;width:max-content;animation:marquee 32s linear infinite}
.ticker:hover .ticker-track{animation-play-state:paused}
.ticker-item{font-family:'JetBrains Mono',monospace;font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);display:inline-flex;align-items:center;gap:56px}
.ticker-item::after{content:"◆";color:var(--orange);font-size:.6rem}

/* ---------- section scaffolding ---------- */
section{padding:120px 0;position:relative}
@media(max-width:720px){section{padding:80px 0}}
.shead{max-width:62ch;margin-bottom:64px}
.shead .eyebrow{margin-bottom:22px}
.shead h2{font-size:clamp(2rem,5vw,3.4rem);font-weight:700;letter-spacing:-.025em}
.shead p{color:var(--muted);font-size:1.1rem;margin-top:18px;max-width:52ch}

/* reveal */
.reveal{opacity:0;transform:translateY(34px);transition:opacity .8s cubic-bezier(.22,.7,.3,1),transform .8s cubic-bezier(.22,.7,.3,1)}
.reveal.in{opacity:1;transform:none}
[data-delay="1"]{transition-delay:.08s}[data-delay="2"]{transition-delay:.16s}
[data-delay="3"]{transition-delay:.24s}[data-delay="4"]{transition-delay:.32s}[data-delay="5"]{transition-delay:.4s}
@media(prefers-reduced-motion:reduce){
  *{animation:none!important}
  .reveal{opacity:1!important;transform:none!important}
  .hero h1 .l span{transform:none!important}
  .hero-eyebrow,.hero p.lead,.hero-cta,.hero-scroll{opacity:1!important}
}

/* ---------- services ---------- */
.services{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
@media(max-width:820px){.services{grid-template-columns:1fr}}
.srow{display:flex;gap:22px;align-items:flex-start;background:linear-gradient(180deg,var(--surface),var(--bg-2));
  border:1px solid var(--line);border-radius:18px;padding:30px 28px;position:relative;overflow:hidden;
  transition:border-color .35s,transform .35s}
.srow::before{content:"";position:absolute;inset:0;border-radius:18px;padding:1px;opacity:0;transition:opacity .35s;
  background:linear-gradient(130deg,var(--orange),transparent 40%);
  -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude}
.srow::after{content:"";position:absolute;width:280px;height:280px;border-radius:50%;top:-140px;right:-140px;
  background:radial-gradient(circle,var(--glow),transparent 70%);opacity:0;transition:opacity .4s;filter:blur(20px)}
.srow:hover{transform:translateY(-4px);border-color:transparent}
.srow:hover::before{opacity:1}
.srow:hover::after{opacity:.16}
.srow .ico{flex:0 0 54px;width:54px;height:54px;border-radius:14px;display:flex;align-items:center;justify-content:center;
  background:rgba(255,106,26,.08);border:1px solid rgba(255,106,26,.2);transition:transform .35s,background .35s}
.srow:hover .ico{transform:scale(1.08) rotate(-3deg);background:rgba(255,106,26,.14)}
.srow .ico svg{width:26px;height:26px;color:var(--orange);fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.srow .body{flex:1;min-width:0}
.srow .body .top{display:flex;align-items:baseline;gap:12px;margin-bottom:14px}
.srow .body .num{font-family:'JetBrains Mono',monospace;font-weight:500;font-size:.78rem;color:var(--orange-deep);letter-spacing:.08em}
.srow .body h3{font-size:1.2rem;font-weight:600}
.srow .body ul{list-style:none;display:flex;flex-direction:column;gap:9px}
.srow .body li{display:flex;align-items:flex-start;gap:10px;color:var(--muted);font-size:.95rem;line-height:1.45}
.srow .body li svg{flex:0 0 14px;width:14px;height:14px;color:var(--orange);margin-top:4px;fill:none;stroke:currentColor;stroke-width:2.6;stroke-linecap:round;stroke-linejoin:round}

/* ---------- why ---------- */
.why{background:linear-gradient(180deg,transparent,rgba(26,23,20,.55),transparent)}
.why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
@media(max-width:980px){.why-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:520px){.why-grid{grid-template-columns:1fr}}
.wcard{background:linear-gradient(180deg,var(--surface),var(--bg-2));border:1px solid var(--line);border-radius:18px;
  padding:30px 26px;position:relative;overflow:hidden;transition:transform .35s,border-color .35s}
.wcard:hover{transform:translateY(-4px);border-color:var(--line-2)}
.wcard .wicon{width:50px;height:50px;border-radius:13px;display:flex;align-items:center;justify-content:center;
  background:rgba(255,106,26,.08);border:1px solid rgba(255,106,26,.18);margin-bottom:22px;position:relative}
.wcard .wicon svg{width:24px;height:24px;color:var(--orange);fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.wcard h3{font-size:1.08rem;font-weight:600;margin-bottom:10px}
.wcard p{color:var(--muted);font-size:.92rem;line-height:1.5}
.wcard .wnum{position:absolute;top:20px;right:22px;font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--muted-2)}

/* ---------- configurator ---------- */
.config{position:relative}
.config-inner{display:grid;grid-template-columns:.85fr 1.15fr;gap:48px;align-items:start}
@media(max-width:900px){.config-inner{grid-template-columns:1fr;gap:32px}}
.config-aside{position:sticky;top:110px}
@media(max-width:900px){.config-aside{position:static}}
.config-aside .eyebrow{margin-bottom:22px}
.config-aside h2{font-size:clamp(1.9rem,4vw,2.8rem);margin-bottom:18px}
.config-aside p{color:var(--muted);font-size:1.02rem;margin-bottom:30px}
.price-live{border:1px solid var(--line);border-radius:16px;padding:22px 24px;
  background:linear-gradient(180deg,var(--surface),var(--bg-2));position:relative;overflow:hidden}
.price-live::before{content:"";position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--orange),transparent);animation:sweep 3s ease-in-out infinite}
.price-live .plabel{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.16em;
  text-transform:uppercase;color:var(--muted-2);line-height:1.7}
.price-live .pval{font-family:'Space Grotesk';font-weight:700;font-size:clamp(2.4rem,7vw,3.4rem);
  color:var(--orange);margin:10px 0 4px;letter-spacing:-.02em}
.price-live .pval .cur{font-size:1.1rem;color:var(--muted);font-weight:500;margin-left:6px}
.price-live .pnote{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--muted-2);letter-spacing:.04em}

.config-box{background:linear-gradient(180deg,var(--surface),var(--bg-2));border:1px solid var(--line);
  border-radius:22px;padding:14px 30px}
@media(max-width:560px){.config-box{padding:8px 20px}}
.cfg-row{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:15px 0;
  border-bottom:1px solid var(--line)}
.cfg-row:last-child{border-bottom:0}
.cfg-info .t{font-weight:600;font-size:1.02rem}
.cfg-info .d{color:var(--muted-2);font-size:.82rem;margin-top:3px;font-family:'JetBrains Mono',monospace;letter-spacing:.02em}
.toggle{position:relative;width:52px;height:29px;flex:0 0 52px;cursor:pointer}
.toggle input{opacity:0;width:0;height:0}
.toggle .track{position:absolute;inset:0;background:#2a2724;border-radius:100px;transition:.3s;border:1px solid var(--line-2)}
.toggle .track::before{content:"";position:absolute;width:21px;height:21px;left:4px;top:3px;background:var(--muted);
  border-radius:50%;transition:.3s}
.toggle input:checked + .track{background:rgba(255,106,26,.22);border-color:var(--orange)}
.toggle input:checked + .track::before{transform:translateX(22px);background:var(--orange);box-shadow:0 0 12px var(--glow)}
.stepper{display:flex;align-items:center;flex:0 0 auto}
.stepper button{width:38px;height:38px;border:1px solid var(--line-2);background:var(--surface-2);color:var(--txt);
  font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s}
.stepper button:first-child{border-radius:10px 0 0 10px}
.stepper button:last-child{border-radius:0 10px 10px 0}
.stepper button:hover{border-color:var(--orange);color:var(--orange)}
.stepper input{width:52px;height:38px;text-align:center;background:var(--bg);border:1px solid var(--line-2);
  border-left:0;border-right:0;color:var(--txt);font-family:'JetBrains Mono',monospace;font-size:.95rem;-moz-appearance:textfield}
.stepper input::-webkit-outer-spin-button,.stepper input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
.sub-rows{display:grid;grid-template-rows:0fr;transition:grid-template-rows .4s ease;overflow:hidden}
.sub-rows.show{grid-template-rows:1fr}
.sub-rows .inner{overflow:hidden;padding-left:4px}
.cfg-form{margin-top:26px;display:grid;grid-template-columns:1fr 1fr;gap:14px}
@media(max-width:560px){.cfg-form{grid-template-columns:1fr}}
.cfg-form .full{grid-column:1/-1}
.fld{width:100%;background:var(--bg);border:1px solid var(--line-2);border-radius:12px;padding:14px 16px;
  color:var(--txt);font-family:inherit;font-size:.96rem;transition:border-color .2s}
.fld:focus{outline:none;border-color:var(--orange)}
textarea.fld{resize:vertical;min-height:84px}
.consent{display:flex;gap:11px;align-items:flex-start;font-size:.8rem;color:var(--muted);line-height:1.5}
.consent input{margin-top:3px;accent-color:var(--orange);flex:0 0 auto}

/* sticky mini price bar (mobile) */
.price-dock{position:fixed;left:0;right:0;bottom:0;z-index:55;
  background:rgba(26,23,20,.9);backdrop-filter:blur(14px);border-top:1px solid var(--line-2);
  padding:12px 20px;display:none;align-items:center;justify-content:space-between;gap:14px;
  transform:translateY(120%);transition:transform .4s cubic-bezier(.4,1.3,.5,1)}
.price-dock.show{transform:translateY(0)}
.price-dock .pd-lbl{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.14em;
  text-transform:uppercase;color:var(--muted-2)}
.price-dock .pd-val{font-family:'Space Grotesk';font-weight:700;font-size:1.5rem;color:var(--orange);line-height:1.1}
.price-dock .pd-val .cur{font-size:.8rem;color:var(--muted);margin-left:4px}
.price-dock a{white-space:nowrap;padding:11px 20px;font-size:.78rem}
@media(max-width:900px){.price-dock{display:flex}}

/* ---------- future / stats ---------- */
.future{text-align:center}
.future-inner{max-width:820px;margin:0 auto}
.future h2{font-size:clamp(2.2rem,6vw,3.8rem)}
.future p{color:var(--muted);font-size:1.12rem;margin:24px auto 0;max-width:54ch}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:60px;
  border-top:1px solid var(--line);padding-top:52px}
.stat .num{font-family:'Space Grotesk';font-weight:700;font-size:clamp(2.4rem,7vw,4rem);color:var(--orange);
  letter-spacing:-.03em;line-height:1}
.stat .num .suf{color:var(--orange-soft)}
.stat .lbl{font-family:'JetBrains Mono',monospace;color:var(--muted);font-size:.78rem;letter-spacing:.1em;
  text-transform:uppercase;margin-top:14px}
@media(max-width:560px){.stats{gap:14px}.stat .lbl{font-size:.64rem}}

/* ---------- gallery ---------- */
.gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
@media(max-width:820px){.gallery{grid-template-columns:1fr 1fr}}
@media(max-width:520px){.gallery{grid-template-columns:1fr}}
.gitem{aspect-ratio:4/3;border-radius:16px;overflow:hidden;position:relative;border:1px solid var(--line);
  background-size:cover;background-position:center;display:flex;align-items:flex-end;padding:22px;
  transition:transform .5s cubic-bezier(.22,.7,.3,1)}
.gitem::after{content:"";position:absolute;inset:0;background:linear-gradient(transparent 25%,rgba(20,18,15,.92));transition:opacity .4s}
.gitem::before{content:"";position:absolute;inset:0;border:1px solid var(--orange);border-radius:16px;opacity:0;
  transition:opacity .4s;z-index:2}
.gitem:hover{transform:scale(1.015)}
.gitem:hover::before{opacity:.6}
.gitem .cap{position:relative;z-index:1;transform:translateY(6px);transition:transform .4s}
.gitem:hover .cap{transform:translateY(0)}
.gitem .cap strong{display:block;font-family:'Space Grotesk';font-weight:600;font-size:1.05rem}
.gitem .cap em{font-style:normal;font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--muted);
  letter-spacing:.04em;opacity:0;transition:opacity .4s}
.gitem:hover .cap em{opacity:1}

/* ---------- contact ---------- */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:860px){.contact-grid{grid-template-columns:1fr}}
.ccard{background:linear-gradient(180deg,var(--surface),var(--bg-2));border:1px solid var(--line);border-radius:20px;padding:32px}
.person{display:flex;gap:16px;align-items:flex-start;padding:20px 0;border-bottom:1px solid var(--line);transition:padding-left .3s}
.person:first-of-type{padding-top:0}
.person:hover{padding-left:6px}
.person .av{width:46px;height:46px;border-radius:12px;background:rgba(255,106,26,.08);border:1px solid rgba(255,106,26,.18);
  display:flex;align-items:center;justify-content:center;flex:0 0 46px}
.person .av svg{width:22px;height:22px;color:var(--orange);fill:none;stroke:currentColor;stroke-width:1.8}
.person .nm{font-family:'Space Grotesk';font-weight:600;font-size:1.08rem}
.person .meta{color:var(--muted);font-size:.9rem;margin-top:4px;font-family:'JetBrains Mono',monospace;letter-spacing:.01em}
.person .meta a{transition:color .2s}.person .meta a:hover{color:var(--orange)}
.loc{display:flex;gap:16px;align-items:center;padding-top:20px}
