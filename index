</footer>

<div class="toast" id="toast">Dziękujemy. Oddzwonimy wkrótce.</div>

<div class="price-dock" id="priceDock">
  <div>
    <div class="pd-lbl">Szacunkowa wycena</div>
    <div class="pd-val" id="priceDockVal">0<span class="cur">zł</span></div>
  </div>
  <a href="#quoteForm" class="btn btn-primary">Zamów wycenę <span class="arrow mono">→</span></a>
</div>

<script>
/* ---------- energy flow canvas ---------- */
(function(){
  const c=document.getElementById('energy');if(!c)return;
  const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const ctx=c.getContext('2d');
  let W,H,DPR,particles=[],paths=[],raf,mouse={x:-999,y:-999};
  function size(){
    DPR=Math.min(window.devicePixelRatio||1,2);
    W=c.width=innerWidth*DPR;H=c.height=innerHeight*DPR;
    c.style.width=innerWidth+'px';c.style.height=innerHeight+'px';
    buildPaths();
  }
  function buildPaths(){
    paths=[];const lanes=Math.max(5,Math.round(innerWidth/220));
    for(let i=0;i<lanes;i++){
      const baseY=(H/(lanes+1))*(i+1);
      const amp=(30+Math.random()*70)*DPR;
      const freq=0.6+Math.random()*1.1;
      const phase=Math.random()*Math.PI*2;
      paths.push({baseY,amp,freq,phase,speed:0.15+Math.random()*0.25});
    }
  }
  function yAt(p,x){return p.baseY+Math.sin((x/W*Math.PI*2*p.freq)+p.phase)*p.amp;}
  function seed(){
    particles=[];const n=reduce?0:Math.round(innerWidth/20);
    for(let i=0;i<n;i++){
      const p=paths[i%paths.length];
      particles.push({p,x:Math.random()*W,v:(0.22+Math.random()*0.5)*DPR,r:(0.5+Math.random()*1.3)*DPR,
        life:Math.random()});
    }
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    ctx.lineWidth=1*DPR;
    paths.forEach(p=>{
      p.phase+=0.0009*p.speed;
      ctx.beginPath();
      for(let x=0;x<=W;x+=14*DPR){const y=yAt(p,x);x===0?ctx.moveTo(x,y):ctx.lineTo(x,y);}
      ctx.strokeStyle='rgba(255,138,60,0.045)';ctx.stroke();
    });
    particles.forEach(pt=>{
      pt.x+=pt.v;if(pt.x>W){pt.x=0;pt.life=Math.random();}
      const y=yAt(pt.p,pt.x);
      const dx=pt.x-mouse.x*DPR,dy=y-mouse.y*DPR,dist=Math.hypot(dx,dy);
      let boost=1;if(dist<120*DPR){boost=1+(1-dist/(120*DPR))*1.8;}
      const g=ctx.createRadialGradient(pt.x,y,0,pt.x,y,pt.r*6*boost);
      g.addColorStop(0,'rgba(255,165,95,'+(0.38*boost)+')');
      g.addColorStop(1,'rgba(255,138,60,0)');
      ctx.fillStyle=g;ctx.beginPath();ctx.arc(pt.x,y,pt.r*6*boost,0,Math.PI*2);ctx.fill();
      ctx.fillStyle='rgba(255,200,150,0.75)';ctx.beginPath();ctx.arc(pt.x,y,pt.r*boost,0,Math.PI*2);ctx.fill();
    });
    raf=requestAnimationFrame(draw);
  }
  function start(){cancelAnimationFrame(raf);seed();if(!reduce)draw();else{ctx.clearRect(0,0,W,H);}}
  addEventListener('resize',()=>{size();start();},{passive:true});
  addEventListener('mousemove',e=>{mouse.x=e.clientX;mouse.y=e.clientY;},{passive:true});
  addEventListener('mouseleave',()=>{mouse.x=-999;mouse.y=-999;});
  document.addEventListener('visibilitychange',()=>{document.hidden?cancelAnimationFrame(raf):(!reduce&&draw());});
  size();start();
})();

/* ---------- header scrolled ---------- */
const header=document.getElementById('header');
addEventListener('scroll',()=>header.classList.toggle('scrolled',scrollY>20),{passive:true});

/* ---------- mobile menu ---------- */
const burger=document.getElementById('burger'),nav=document.getElementById('navlinks');
burger.addEventListener('click',()=>{const o=nav.classList.toggle('open');burger.classList.toggle('open',o);
  document.body.style.overflow=o?'hidden':'';});
nav.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{nav.classList.remove('open');burger.classList.remove('open');document.body.style.overflow='';}));

/* ---------- reveal on scroll ---------- */
(function(){
  const els=document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){els.forEach(e=>e.classList.add('in'));return;}
  const io=new IntersectionObserver((en)=>{en.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},
    {threshold:.14,rootMargin:'0px 0px -6% 0px'});
  els.forEach(e=>io.observe(e));
})();

/* ---------- count-up stats ---------- */
(function(){
  const nums=document.querySelectorAll('[data-count]');
  const io=new IntersectionObserver((en)=>{en.forEach(e=>{
    if(!e.isIntersecting)return;io.unobserve(e.target);
    const el=e.target,target=+el.dataset.count,suf=el.querySelector('.suf'),sufTxt=suf?suf.outerHTML:'';
    const dur=1400,t0=performance.now();
    function tick(t){const p=Math.min((t-t0)/dur,1);const val=Math.round((1-Math.pow(1-p,3))*target);
      el.innerHTML=val+sufTxt;if(p<1)requestAnimationFrame(tick);}
    requestAnimationFrame(tick);
  });},{threshold:.5});
  nums.forEach(n=>io.observe(n));
})();

/* ---------- ticker seamless loop ---------- */
(function(){const t=document.getElementById('ticker');if(t)t.innerHTML+=t.innerHTML;})();

/* ---------- mobile price dock visibility ---------- */
(function(){
  const dock=document.getElementById('priceDock'),sec=document.getElementById('wycena');
  if(!dock||!sec)return;
  const io=new IntersectionObserver((en)=>{en.forEach(e=>dock.classList.toggle('show',e.isIntersecting));},
    {threshold:.04});
  io.observe(sec);
})();

/* ---------- hero parallax ---------- */
(function(){
  const reduce=window.matchMedia('(prefers-reduced-motion: reduce)').matches;if(reduce)return;
  const h1=document.querySelector('.hero h1'),lead=document.querySelector('.hero .lead');
  addEventListener('scroll',()=>{const y=scrollY;if(y<900){
    if(h1)h1.style.transform='translateY('+y*0.12+'px)';
    if(lead)lead.style.transform='translateY('+y*0.06+'px)';
  }},{passive:true});
})();

/* ---------- configurator ---------- */
document.querySelectorAll('.stepper').forEach(s=>{
  const inp=s.querySelector('input'),min=+(s.dataset.min||0);
  s.querySelectorAll('button').forEach(b=>b.addEventListener('click',()=>{
    inp.value=Math.max(min,(+inp.value||0)+(+b.dataset.dir));calc();}));
  inp.addEventListener('input',calc);
});
document.querySelectorAll('.toggle input').forEach(t=>t.addEventListener('change',()=>{
  const tgt=t.dataset.target;
  if(tgt){const g=document.getElementById(tgt);g.classList.toggle('show',t.checked);
    if(!t.checked)g.querySelectorAll('input[type=number]').forEach(i=>i.value=0);}
  calc();
}));
let lastPrice=0;
function calc(){
  let total=0;
  const rooms=document.getElementById('rooms');total+=(+rooms.value||0)*(+rooms.dataset.base);
  document.querySelectorAll('.sub-rows').forEach(g=>{
    const active=document.querySelector('[data-target="'+g.id+'"]').checked;if(!active)return;
    g.querySelectorAll('input[type=number]').forEach(i=>total+=(+i.value||0)*(+i.dataset.base));
  });
  document.querySelectorAll('[data-flat]').forEach(f=>{if(f.checked)total+=+f.dataset.flat;});
  animatePrice(lastPrice,total);lastPrice=total;
}
function animatePrice(from,to){
  const el=document.getElementById('priceOut');const dock=document.getElementById('priceDockVal');
  const t0=performance.now(),dur=450;
  function tick(t){const p=Math.min((t-t0)/dur,1);const v=Math.round(from+(to-from)*(1-Math.pow(1-p,3)));
    const html=v.toLocaleString('pl-PL')+'<span class="cur">zł</span>';
    el.innerHTML=html;if(dock)dock.innerHTML=html;if(p<1)requestAnimationFrame(tick);}
  requestAnimationFrame(tick);
}
calc();

/* ---------- forms ---------- */
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3600);}
document.getElementById('quoteForm').addEventListener('submit',e=>{e.preventDefault();toast('Dziękujemy. Oddzwonimy z wyceną.');e.target.reset();calc();});
document.getElementById('contactForm').addEventListener('submit',e=>{e.preventDefault();toast('Zapytanie wysłane. Odezwiemy się wkrótce.');e.target.reset();});

document.getElementById('yr').textContent=new Date().getFullYear();
</script>
</body>
</html>
